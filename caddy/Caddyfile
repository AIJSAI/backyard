# Local and clean-machine repro: plain HTTP on :8000, proxying to the web container.
# The database and app containers publish no ports; only this proxy is exposed (TM-8).
#
# For a real deployment, replace the :8000 block with your domain and Caddy fetches a
# TLS certificate automatically:
#
#   backyard.example.com {
#       reverse_proxy web:8000
#       request_body { max_size 512MB }
#       header Referrer-Policy no-referrer
#       header X-Content-Type-Options nosniff
#   }
#
# Do NOT add a `log` directive here: request lines carry bearer tokens in their
# paths (/d/, /join/, /media/, /digest/*, /break-glass/ — threat model
# TS-EDGE-LOG). If you need edge access logs, redact those paths first.

{
	admin off
	auto_https off
}

:8000 {
	reverse_proxy web:8000
	# Hard edge ceiling on the request body (TS-CA-4): rejects an oversized or
	# many-file POST with a 413 before the multipart parser writes temp files or the
	# app buffers it, above the largest legitimate post (4 clips at 100MB + photos).
	# The per-file app-layer caps (media) are the fine control beneath this.
	request_body {
		max_size 512MB
	}
	header {
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		-Server
	}
}
