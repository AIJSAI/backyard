# Copy to .env and set a strong POSTGRES_PASSWORD (or run `make up`, which generates one).
#
# The Django SECRET_KEY is deliberately NOT set here. The container generates it and
# persists it at first boot (docs/security/threat-model.md, TM-8). There are no default
# credentials anywhere: compose refuses to start until POSTGRES_PASSWORD is set.

POSTGRES_PASSWORD=

# Optional overrides (defaults shown):
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
# BACKYARD_BASE_URL=http://localhost:8000
# POSTGRES_DB=backyard
# POSTGRES_USER=backyard
